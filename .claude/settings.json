{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/autosave.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "FORCE_SAVE=1 bash scripts/autosave.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
