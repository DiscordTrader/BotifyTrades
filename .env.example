# ============================================================
# Ψ∿ QuantumPulse - Environment Variables Template
# Professional Discord Trading Bot
# ============================================================
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env (remove .example)
# 2. Fill in your actual credentials below (remove the example values)
# 3. NO quotes needed around values!
# 4. NEVER commit the .env file to git (it's in .gitignore)
#
# ============================================================

# ------------------------------------------------------------
# DISCORD CONFIGURATION (REQUIRED)
# ------------------------------------------------------------
# Get your Discord token:
# 1. Open Discord in Chrome/Firefox browser (not the desktop app)
# 2. Press F12 to open Developer Tools
# 3. Go to Console tab
# 4. Paste this code and press Enter:
#    (webpackChunkdiscord_app.push([[''],{},e=>{m=[];for(let c in e.c)m.push(e.c[c])}]),m).find(m=>m?.exports?.default?.getToken!==void 0).exports.default.getToken()
# 5. Copy the long token that appears

DISCORD_USER_TOKEN=your_discord_token_here_no_quotes

# ------------------------------------------------------------
# WEBULL CONFIGURATION (REQUIRED)
# ------------------------------------------------------------

# Your 6-digit Webull trading PIN
WEBULL_TRADE_PIN=123456

# ============================================================
# WEBULL AUTHENTICATION - Choose ONE method below:
# ============================================================

# ------------------------------------------------------------
# METHOD 1: Token Authentication (RECOMMENDED - Faster)
# ------------------------------------------------------------
# Get these from your browser after logging into Webull:
# 1. Open Webull website in browser and log in
# 2. Press F12 → Application/Storage → Cookies
# 3. Find: access_token, refresh_token, did
# 4. Copy the values below

WEBULL_ACCESS_TOKEN=your_access_token_here
WEBULL_REFRESH_TOKEN=your_refresh_token_here
WEBULL_DID=your_device_id_here

# ------------------------------------------------------------
# METHOD 2: Username/Password (Alternative)
# ------------------------------------------------------------
# If you don't have tokens, uncomment and use these instead:

# WEBULL_USERNAME=your_email@example.com
# WEBULL_PASSWORD=your_webull_password

# ------------------------------------------------------------
# LICENSE KEY (OPTIONAL - 7-day free trial included)
# ------------------------------------------------------------
# Leave empty for automatic 7-day free trial
# Enter your subscription license key here after trial ends

LICENSE_KEY=

# ------------------------------------------------------------
# API KEYS (OPTIONAL - For advanced features)
# ------------------------------------------------------------

# OpenAI API Key - For AI-powered trade analysis
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Alpha Vantage API Key - For option flow scanning
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub API Key - For real-time market news
# Get from: https://finnhub.io/register
FINNHUB_API_KEY=

# Alpaca API Keys - For live option chains with Greeks
# Get from: https://alpaca.markets (free tier available)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ------------------------------------------------------------
# DISCORD WEBHOOK (OPTIONAL - For trade notifications)
# ------------------------------------------------------------
# Configure in Settings page or use these env vars
# Webhook URL format: https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_CHANNEL_ID=

# ------------------------------------------------------------
# TRADING SETTINGS (OPTIONAL - Override config.ini)
# ------------------------------------------------------------

# Set to true for paper trading (test mode, no real money)
PAPER_TRADE=false

# Maximum position size in dollars
MAX_POSITION_SIZE=1000

# Risk management percentages
PROFIT_TARGET_PCT=20
STOP_LOSS_PCT=10
TRAILING_STOP_PCT=5

# ============================================================
# IMPORTANT SECURITY NOTES
# ============================================================
# - The .env file is already in .gitignore (safe from git)
# - Never share your .env file or tokens with anyone
# - Rotate your Discord token if it's ever exposed
# - Use token authentication when possible (more secure)
# - Trading PIN should be exactly 6 digits
#
# ============================================================
# CONFIGURATION PRECEDENCE (How bot loads settings)
# ============================================================
# 1. GUI Settings Page (highest priority - stored in database)
# 2. Environment Variables (.env file or system env vars)
# 3. config.ini file (lowest priority - fallback)
#
# Best Practice:
# - Use .env for local development
# - Use config.ini for quick testing
# - Use GUI Settings for production deployments
